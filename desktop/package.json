{
  "name": "@fecommunity/reactpress-desktop",
  "version": "3.0.0",
  "private": true,
  "description": "ReactPress Admin desktop shell (Electron)",
  "main": "out/main/index.js",
  "author": "fecommunity",
  "license": "ISC",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "node ./scripts/ensure-electron.mjs",
    "dev": "pnpm run build && cross-env ELECTRON_IS_DEV=1 electron .",
    "dev:shell": "pnpm run build && cross-env ELECTRON_IS_DEV=1 electron .",
    "dist": "pnpm run build && electron-builder --config electron-builder.yml",
    "dist:dir": "pnpm run build && electron-builder --config electron-builder.yml --dir",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "electron": "^35.0.3",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.3"
  },
  "build": {
    "appId": "com.reactpress.desktop",
    "productName": "ReactPress",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "renderer",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "resources/icon.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "resources/icon.png",
      "category": "Office"
    }
  }
}
