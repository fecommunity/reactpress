{
  "$schema": "../plugin.manifest.schema.json",
  "id": "image-optimizer",
  "name": "图片资源优化",
  "version": "1.0.0",
  "description": "分析历史图片素材并批量压缩为 WebP 多尺寸变体，可选回写文章与页面中的图片 URL。",
  "author": "ReactPress",
  "requires": ">=3.5.0",
  "server": {
    "module": "./dist/index.js"
  },
  "admin": {
    "menu": {
      "title": "图片优化",
      "path": "/plugins/image-optimizer/settings",
      "permission": "extension:manage",
      "sort": 30
    }
  },
  "settings": {
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "batchSize": {
          "type": "integer",
          "title": "每批处理数量",
          "description": "单次任务最多处理的图片数量（1–200）。",
          "minimum": 1,
          "maximum": 200,
          "default": 50
        },
        "skipGif": {
          "type": "boolean",
          "title": "跳过 GIF",
          "description": "GIF 转 WebP 后会失去动画，默认跳过。",
          "default": true
        },
        "rewriteContent": {
          "type": "boolean",
          "title": "优化后回写内容 URL",
          "description": "批量优化完成后，自动替换文章/页面中引用的旧图片地址。",
          "default": false
        },
        "cleanupOriginals": {
          "type": "boolean",
          "title": "优化后删除原文件",
          "description": "确认无误后再开启；删除后无法通过旧 URL 访问原图。",
          "default": false
        }
      }
    }
  },
  "permissions": ["file:read", "file:write", "article:read"],
  "capabilities": {
    "headless": true
  }
}
