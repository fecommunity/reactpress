{
  "id": "twentytwentysix",
  "name": "Twenty Twenty-Six",
  "version": "1.0.0",
  "description": "由 ReactPress client 迁移的双栏博客主题，保留导航/知识库/归档等访客功能。",
  "author": "ReactPress",
  "tags": ["博客", "双栏", "知识库", "归档", "导航"],
  "reactpress": {
    "requires": ">=3.0.0",
    "templates": {
      "home": "pages/index.tsx",
      "single": "pages/article/[id].tsx",
      "page": "pages/page/[id].tsx",
      "archive-category": "pages/category/[category].tsx",
      "archive-tag": "pages/tag/[tag].tsx",
      "search": "pages/search.tsx",
      "404": "pages/404.tsx"
    },
    "supports": { "darkMode": true, "menus": ["primary", "footer"] }
  },
  "customizer": {
    "sections": [
      {
        "id": "identity",
        "title": "站点身份",
        "settings": [
          {
            "id": "siteLogo",
            "type": "image",
            "label": "站点 Logo",
            "description": "留空则使用后台「站点 Logo」(systemLogo)"
          },
          {
            "id": "displayTitle",
            "type": "text",
            "label": "站点标题",
            "description": "留空则使用后台「站点标题」(systemTitle)"
          },
          {
            "id": "displayTagline",
            "type": "text",
            "label": "站点副标题",
            "description": "留空则使用后台「站点副标题」(systemSubTitle)"
          }
        ]
      },
      {
        "id": "colors",
        "title": "颜色与深色模式",
        "settings": [
          { "id": "primaryColor", "type": "color", "label": "主色", "default": "#c40000" },
          { "id": "backgroundColor", "type": "color", "label": "背景色", "default": "#f5f5f5" },
          {
            "id": "darkMode",
            "type": "checkbox",
            "label": "启用深色模式",
            "default": "1",
            "description": "开启后站点使用深色背景与浅色文字"
          }
        ]
      },
      {
        "id": "background",
        "title": "背景图片",
        "settings": [
          {
            "id": "backgroundImage",
            "type": "image",
            "label": "背景图",
            "description": "设置后将覆盖纯色背景（宽屏可见）"
          }
        ]
      }
    ]
  }
}
