{
  "id": "hello-world",
  "name": "Hello World",
  "version": "1.0.0",
  "description": "Hello Elementor 风格的入门主题，含文章、分类、标签与搜索等基础模板。",
  "author": "ReactPress",
  "tags": ["入门", "博客", "Hello"],
  "reactpress": {
    "requires": ">=3.0.0",
    "supports": { "darkMode": false, "menus": ["primary"] },
    "templates": {
      "home": "pages/index.tsx",
      "single": "pages/article/[id].tsx",
      "page": "pages/about.tsx",
      "archive-category": "pages/category/[category].tsx",
      "archive-tag": "pages/tag/[tag].tsx",
      "search": "pages/search.tsx",
      "404": "pages/404.tsx"
    }
  },
  "customizer": {
    "sections": [
      {
        "id": "colors",
        "title": "颜色",
        "settings": [
          { "id": "primaryColor", "type": "color", "label": "主色", "default": "#c02b5a" },
          { "id": "backgroundColor", "type": "color", "label": "背景色", "default": "#ffffff" }
        ]
      },
      {
        "id": "identity",
        "title": "站点身份",
        "settings": [
          { "id": "displayTitle", "type": "text", "label": "展示标题", "default": "My Site" },
          {
            "id": "displayTagline",
            "type": "text",
            "label": "站点副标题",
            "default": "A ReactPress powered site"
          }
        ]
      }
    ]
  }
}
