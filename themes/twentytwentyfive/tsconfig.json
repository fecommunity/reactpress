{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@fecommunity/reactpress-toolkit": ["../../toolkit/dist/index.js"],
      "@fecommunity/reactpress-toolkit/api": ["../../toolkit/dist/api/index.js"],
      "@fecommunity/reactpress-toolkit/config": ["../../toolkit/dist/config/index.js"],
      "@fecommunity/reactpress-toolkit/plugin": ["../../toolkit/dist/plugin/index.js"],
      "@fecommunity/reactpress-toolkit/plugin/admin": ["../../toolkit/dist/plugin/admin/index.js"],
      "@fecommunity/reactpress-toolkit/plugin/client": ["../../toolkit/dist/plugin/client/index.js"],
      "@fecommunity/reactpress-toolkit/plugin/react": ["../../toolkit/dist/plugin/react/index.js"],
      "@fecommunity/reactpress-toolkit/plugin/dev": ["../../toolkit/dist/plugin/dev/index.js"],
      "@fecommunity/reactpress-toolkit/theme": ["../../toolkit/dist/theme/index.js"],
      "@fecommunity/reactpress-toolkit/theme/next-config": ["../../toolkit/dist/theme/next-config.js"],
      "@fecommunity/reactpress-toolkit/app": ["../../toolkit/dist/app/index.js"],
      "@fecommunity/reactpress-toolkit/types": ["../../toolkit/dist/types/index.js"],
      "@fecommunity/reactpress-toolkit/ui": ["../../toolkit/dist/ui/index.js"],
      "@fecommunity/reactpress-toolkit/ui/content": ["../../toolkit/dist/ui/components/content/index.js"],
      "@fecommunity/reactpress-toolkit/utils": ["../../toolkit/dist/utils/index.js"]
    },
    "incremental": true,
    "moduleResolution": "node"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".next"]
}
