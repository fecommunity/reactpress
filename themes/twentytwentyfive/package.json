    "highlight.js": "^9.18.5",
    "mime-types": "^2.1.26",
    "next": "^12.3.4",
    "next-intl": "^1.5.1",
    "next-sitemap": "^1.6.102",
    "nprogress": "^0.2.0",
    "open": "^8.4.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viewerjs": "^1.5.0",
    "xml": "^1.0.1",
    "typescript": "~4.9.5"
  },
  "devDependencies": {
    "@types/node": "17.0.22",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.6",
