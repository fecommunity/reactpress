{
  "name": "@fecommunity/reactpress-template-twentytwentyfive",
  "version": "3.0.6",
  "bin": {
    "reactpress-client": "./bin/reactpress-client.js"
  },
  "files": [
    ".next/**/*",
    "bin/**/*",
    "public/**/*",
    "next.config.js",
    "server.js"
  ],
  "scripts": {
