# 管理后台 dev 端口（与根目录 .env 中 WEB_ADMIN_PORT 一致，默认 3000）
# WEB_ADMIN_PORT=3000

# Dev 默认 /api（同源 + Vite 代理）；勿设置跨域绝对地址的 VITE_API_BASE_URL
# VITE_API_BASE_URL=/api

# 本地 dev 时 /api 代理目标（vite.config.ts 读取）
# VITE_DEV_API_PROXY_TARGET=https://api.gaoredu.com
# 联调本机 Nest API 时可改为：
# VITE_DEV_API_PROXY_TARGET=http://localhost:3002

# mock = MSW（admin/admin）；server = 真实 API（字段 name + password）
# 使用远程 API 时必须 VITE_ENABLE_MOCK=false，否则 MSW 会拦截 /api 返回 mock
# VITE_AUTH_MODE=server
# VITE_ENABLE_MOCK=false

# 仅 Mock 本地开发（不连远程）时，在 .env.development.local 覆盖：
# VITE_ENABLE_MOCK=true
# VITE_AUTH_MODE=mock
# VITE_DEV_API_PROXY_TARGET=http://localhost:3002

# Set true to keep MSW in production builds (not recommended)
# VITE_ENABLE_MOCK=true
